# ╔═══════════════════════════════════════════════════════════╗
# ║  SENTINEL CV Pipeline — Environment Variables             ║
# ╚═══════════════════════════════════════════════════════════╝
# Copy to .env and fill in your values

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092

# ── CV Service ────────────────────────────────────────────────
CAMERA_ID=cam_001
CAMERA_LAT=40.7580
CAMERA_LON=-73.9855
YOLO_MODEL=yolov8n.pt          # yolov8n.pt (fast) | yolov8s.pt (balanced) | yolov8m.pt (accurate)
CONFIDENCE_THRESHOLD=0.35

# Video source: file path, RTSP URL, or camera index
# Examples:
#   VIDEO_SOURCE=./demo/traffic_sample.mp4
#   VIDEO_SOURCE=https://camera-feed-url/stream.m3u8
#   VIDEO_SOURCE=rtsp://user:pass@camera-ip:554/stream
#   VIDEO_SOURCE=0   (webcam)
VIDEO_SOURCE=./demo/traffic_sample.mp4

# ── Spark ─────────────────────────────────────────────────────
SPARK_CHECKPOINT=/tmp/sentinel-spark-checkpoints

# ── Database (Phase 3+) ──────────────────────────────────────
POSTGRES_URL=jdbc:postgresql://localhost:5432/sentinel
POSTGRES_USER=sentinel
POSTGRES_PASS=sentinel

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
